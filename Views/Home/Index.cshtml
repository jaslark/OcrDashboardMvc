@model OcrDashboardMvc.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <header class="bg-white border-b border-gray-200 sticky top-0 z-10">
        <div class="max-w-[1400px] mx-auto px-6 py-4">
      <div class="flex items-center justify-between">
  <div>
        <h1 class="text-gray-900 text-2xl font-medium">Dashboard Phân Tích OCR</h1>
       <p class="text-gray-600 mt-1">Theo dõi hiệu suất và chất lượng xử lý OCR báo cáo tài chính</p>
             </div>
  <button onclick="toggleFilters()"
            class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
         <i data-lucide="filter" class="w-4 h-4"></i>
                    Bộ lọc
      </button>
   </div>
</div>
    </header>

    <!-- Filters Panel -->
    <div id="filtersPanel" class="bg-white border-b border-gray-200 hidden sticky top-[73px] z-10 shadow-lg">
        <div class="max-w-[1400px] mx-auto px-6 py-4">
       <partial name="_DashboardFilters" model="Model.Filters" />
        </div>
    </div>

    <!-- Main Content -->
    <main class="max-w-[1400px] mx-auto px-6 py-6 space-y-6">
        <!-- Part 1: Tổng quan OCR -->
        <section>
     <h2 class="text-gray-900 mb-4 text-xl font-medium">Phần 1. Tổng quan OCR</h2>
    <div class="space-y-4">
    <partial name="_OCROverview" model="Model.Stats" />
         <partial name="_LicenseStatus" model="Model" />
            </div>
        </section>

 <!-- Part 2: Phân tích chất lượng & hiệu suất -->
        <section>
            <h2 class="text-gray-900 mb-4 text-xl font-medium">Phần 2. Phân tích Chất Lượng & Hiệu Suất</h2>
            <div class="space-y-4">
   <partial name="_PerformanceTrends" model="Model" />
        <partial name="_TemplateAnalysis" model="Model" />
            </div>
   </section>

  <!-- Part 3: Phân tích lỗi & cải thiện OCR -->
    <section>
  <h2 class="text-gray-900 mb-4 text-xl font-medium">Phần 3. Phân tích Lỗi & Cải Thiện OCR</h2>
       <div class="space-y-4">
     <partial name="_ScatterAnalysis" model="Model.ScatterData" />
    <partial name="_PerformanceHeatmap" model="Model.HeatmapData" />
    <partial name="_TopWorstFiles" model="Model" />
       </div>
   </section>
    </main>
</div>

<script>
    function toggleFilters() {
        const panel = document.getElementById('filtersPanel');
  const isHidden = panel.classList.contains('hidden');
        
        // Toggle visibility
panel.classList.toggle('hidden');
 
        // Nếu đang mở panel, scroll lên đầu trang để thấy filter
        if (isHidden) {
       window.scrollTo({
      top: 0,
          behavior: 'smooth'
        });
        }
        
  // Re-initialize lucide icons
        if (typeof lucide !== 'undefined') {
       lucide.createIcons();
        }
    }
</script>
