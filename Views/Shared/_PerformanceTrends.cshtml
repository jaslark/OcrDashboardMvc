@model OcrDashboardMvc.Models.DashboardViewModel

@{
    var performanceTrendsData = Model.PerformanceTrendsData ?? new OcrDashboardMvc.Models.PerformanceTrendsData { MonthlyTrends = new List<OcrDashboardMvc.Models.MonthlyPerformanceTrend>() };
}

<div class="bg-white rounded-lg border border-gray-200 p-6">
    <div class="flex items-center gap-2 mb-4">
        <i data-lucide="trending-up" class="w-5 h-5 text-gray-700"></i>
        <h3 class="text-gray-900">1. Xu hướng hiệu suất theo tháng</h3>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Success Rate & Accuracy -->
        <div>
            <h4 class="text-gray-700 mb-3">Tỷ lệ thành công & Độ chính xác (%)</h4>
            <div style="height: 300px;">
                <canvas id="successAccuracyChart"></canvas>
            </div>
        </div>

        <!-- Processing Speed -->
        <div>
            <h4 class="text-gray-700 mb-3">Tốc độ xử lý trung bình (giây/trang)</h4>
            <div style="height: 300px;">
                <canvas id="speedChart"></canvas>
            </div>
        </div>

        <!-- License Usage Trend -->
        <div class="lg:col-span-2">
            <h4 class="text-gray-700 mb-3">Số license đã sử dụng theo tháng</h4>
            <div style="height: 300px;">
                <canvas id="licenseChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        // Lấy dữ liệu từ server-side
        var performanceTrendsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(performanceTrendsData.MonthlyTrends));

        // Chuẩn bị labels và datasets
        var labels = performanceTrendsData.map(d => d.Month);

        // Chart 1: Success & Accuracy
        new Chart(document.getElementById('successAccuracyChart'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Tỷ lệ thành công',
                        data: performanceTrendsData.map(d => d.SuccessRate),
                        borderColor: '#10b981',
                        backgroundColor: '#10b981',
                        tension: 0.4
                    },
                    {
                        label: 'Độ chính xác',
                        data: performanceTrendsData.map(d => d.Accuracy),
                        borderColor: '#3b82f6',
                        backgroundColor: '#3b82f6',
                        tension: 0.4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y.toFixed(1) + '%';
                            }
                        }
                    }
                },
                scales: {
                    y: { 
                        min: 0, 
                        max: 100,
                        ticks: {
                            callback: function(value) {
                                return value + '%';
                            }
                        }
                    }
                }
            }
        });

        // Chart 2: Speed
        new Chart(document.getElementById('speedChart'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'Tốc độ TB',
                        data: performanceTrendsData.map(d => d.AvgSpeed),
                        borderColor: '#8b5cf6',
                        backgroundColor: '#8b5cf6',
                        tension: 0.4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y.toFixed(1) + ' giây/trang';
                            }
                        }
                    }
                },
                scales: {
                    y: { 
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return value.toFixed(1) + 's';
                            }
                        }
                    }
                }
            }
        });

        // Chart 3: Licenses
        new Chart(document.getElementById('licenseChart'), {
            type: 'line',
            data: {
                labels: labels,
                datasets: [
                    {
                        label: 'License sử dụng (Pages)',
                        data: performanceTrendsData.map(d => d.Licenses),
                        borderColor: '#f59e0b',
                        backgroundColor: 'rgba(245, 158, 11, 0.1)',
                        tension: 0.4,
                        fill: true
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                return context.dataset.label + ': ' + context.parsed.y.toLocaleString() + ' pages';
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            callback: function(value) {
                                return value.toLocaleString();
                            }
                        }
                    }
                }
            }
        });
    });
</script>

