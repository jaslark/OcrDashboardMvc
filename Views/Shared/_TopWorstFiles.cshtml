@model OcrDashboardMvc.Models.DashboardViewModel

@{
    string GetPerformanceBadge(double accuracy)
    {
        if (accuracy >= 90) return "bg-green-100 text-green-700";
        if (accuracy >= 80) return "bg-yellow-100 text-yellow-700";
        return "bg-red-100 text-red-700";
    }

    string GetTemplateDisplayName(string template)
    {
        return template == "Unknown" ? "Không xác định" : template;
    }
}

<div class="bg-white rounded-lg border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
        <div class="flex items-center gap-2">
            <i data-lucide="alert-triangle" class="w-5 h-5 text-orange-600"></i>
            <h3 class="text-gray-900">3. Top 10 file cần cải thiện</h3>
        </div>
        <div class="text-xs text-gray-500 italic">
            <i data-lucide="filter" class="w-3 h-3 inline"></i>
            Dữ liệu theo bộ lọc đã chọn
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Worst Accuracy -->
        <div>
            <div class="flex items-center gap-2 mb-3">
                <i data-lucide="target" class="w-5 h-5 text-red-600"></i>
                <h4 class="text-gray-900 font-semibold">Top 10 file độ chính xác thấp nhất</h4>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full border-2 border-red-200 rounded-lg">
                    <thead>
                        <tr class="border-b border-gray-200 bg-red-50">
                            <th class="text-center py-2 px-2 text-gray-700 whitespace-nowrap" style="width: 30px;">#</th>
                            <th class="text-center py-2 px-2 text-gray-700" style="max-width: 180px;">Tên tệp OCR</th>
                            <th class="text-center py-2 px-2 text-gray-700 whitespace-nowrap" style="width: 90px;">Mẫu</th>
                            <th class="text-center py-2 px-2 text-gray-700 whitespace-nowrap" style="width: 90px;">Ngày OCR</th>
                            <th class="text-center py-2 px-2 text-gray-700 whitespace-nowrap" style="width: 90px;">Độ chính xác</th>
                            <th class="text-center py-2 px-2 text-gray-700 whitespace-nowrap" style="width: 70px;">Thời gian</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white">
                        @for (int i = 0; i < Model.WorstAccuracyFiles.Count; i++)
                        {
                            var file = Model.WorstAccuracyFiles[i];
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-2 px-2 text-center text-gray-600 whitespace-nowrap">@(i + 1)</td>
                                <td class="py-2 px-2 text-gray-900" style="max-width: 180px;">
                                    <div class="truncate" title="@file.RecordCode">@file.RecordCode</div>
                                </td>
                                <td class="py-2 px-2 whitespace-nowrap">
                                    <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded text-xs">
                                        @GetTemplateDisplayName(file.Template)
                                    </span>
                                </td>
                                <td class="py-2 px-2 text-center text-gray-600 whitespace-nowrap text-sm">@file.OcrDate</td>
                                <td class="py-2 px-2 text-center whitespace-nowrap">
                                    <span class="px-2 py-1 rounded text-xs @GetPerformanceBadge(file.Accuracy)">
                                        @file.Accuracy%
                                    </span>
                                </td>
                                <td class="py-2 px-2 text-center text-gray-900 whitespace-nowrap text-sm">@file.ProcessingTime s</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Slowest Processing -->
        <div>
            <div class="flex items-center gap-2 mb-3">
                <i data-lucide="clock" class="w-5 h-5 text-orange-600"></i>
                <h4 class="text-gray-900 font-semibold">Top 10 file xử lý chậm nhất</h4>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full border-2 border-orange-200 rounded-lg">
                    <thead>
                        <tr class="border-b border-gray-200 bg-orange-50">
                            <th class="text-center py-2 px-2 text-gray-700 whitespace-nowrap" style="width: 30px;">#</th>
                            <th class="text-center py-2 px-2 text-gray-700" style="max-width: 180px;">Tên tệp OCR</th>
                            <th class="text-center py-2 px-2 text-gray-700 whitespace-nowrap" style="width: 90px;">Mẫu</th>
                            <th class="text-center py-2 px-2 text-gray-700 whitespace-nowrap" style="width: 90px;">Ngày OCR</th>
                            <th class="text-center py-2 px-2 text-gray-700 whitespace-nowrap" style="width: 70px;">Thời gian</th>
                            <th class="text-center py-2 px-2 text-gray-700 whitespace-nowrap" style="width: 90px;">Độ chính xác</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white">
                        @for (int i = 0; i < Model.SlowestFiles.Count; i++)
                        {
                            var file = Model.SlowestFiles[i];
                            <tr class="border-b border-gray-100 hover:bg-gray-50">
                                <td class="py-2 px-2 text-center text-gray-600 whitespace-nowrap">@(i + 1)</td>
                                <td class="py-2 px-2 text-gray-900" style="max-width: 180px;">
                                    <div class="truncate" title="@file.RecordCode">@file.RecordCode</div>
                                </td>
                                <td class="py-2 px-2 whitespace-nowrap">
                                    <span class="px-2 py-1 bg-blue-100 text-blue-700 rounded text-xs">
                                        @GetTemplateDisplayName(file.Template)
                                    </span>
                                </td>
                                <td class="py-2 px-2 text-center text-gray-600 whitespace-nowrap text-sm">@file.OcrDate</td>
                                <td class="py-2 px-2 text-center whitespace-nowrap">
                                    <span class="px-2 py-1 bg-orange-100 text-orange-700 rounded text-xs">
                                        @file.ProcessingTime s
                                    </span>
                                </td>
                                <td class="py-2 px-2 text-center whitespace-nowrap">
                                    <span class="px-2 py-1 rounded text-xs @GetPerformanceBadge(file.Accuracy)">
                                        @file.Accuracy%
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Summary -->
    @{
        // Phân tích dữ liệu thực
        var worstTemplates = Model.WorstAccuracyFiles
            .GroupBy(f => f.Template)
            .OrderByDescending(g => g.Count())
            .FirstOrDefault();
        
        var slowFiles = Model.SlowestFiles
            .Where(f => f.Pages > 15)
            .Count();
        
        var lowAccuracyCount = Model.WorstAccuracyFiles
            .Where(f => f.Accuracy < 75)
            .Count();
        
        var avgWorstAccuracy = Model.WorstAccuracyFiles.Any() 
            ? Math.Round(Model.WorstAccuracyFiles.Average(f => f.Accuracy), 1)
            : 0;
        
        var avgSlowestTime = Model.SlowestFiles.Any()
            ? Math.Round(Model.SlowestFiles.Average(f => f.ProcessingTime), 1)
            : 0;
    }
    <div class="mt-6 p-4 bg-orange-50 border border-orange-200 rounded-lg">
        <div class="flex items-start gap-2">
            <i data-lucide="alert-triangle" class="w-5 h-5 text-orange-600 mt-0.5"></i>
            <div>
                <div class="text-gray-900 mb-1">Phân tích & Đề xuất</div>
                <ul class="text-gray-700 space-y-1">
                    @if (worstTemplates != null && worstTemplates.Count() > 1)
                    {
                        <li>• Mẫu <span class="text-orange-700">@GetTemplateDisplayName(worstTemplates.Key)</span> chiếm @worstTemplates.Count()/@Model.WorstAccuracyFiles.Count file trong danh sách - cần rà soát và cải thiện model OCR cho mẫu này</li>
                    }
                    @if (slowFiles > 0)
                    {
                        <li>• Có @slowFiles file với số trang lớn (>15 trang) có thời gian xử lý cao - cần tối ưu hóa batch processing</li>
                    }
                    @if (lowAccuracyCount > 0)
                    {
                        <li>• Có @lowAccuracyCount file có độ chính xác dưới 75% - nên được kiểm tra lại bằng manual review</li>
                    }
                </ul>
            </div>
        </div>
    </div>
</div>
