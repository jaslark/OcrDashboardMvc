@model List<OcrDashboardMvc.Models.ScatterData>

<div class="bg-white rounded-lg border border-gray-200 p-6">
    <div class="flex items-center justify-between mb-4">
  <div class="flex items-center gap-2">
        <i data-lucide="activity" class="w-5 h-5 text-gray-700"></i>
            <h3 class="text-gray-900">1. Phân tích hiệu suất OCR (Scatter Chart)</h3>
  </div>
  <div class="text-xs text-gray-500 italic">
        <i data-lucide="filter" class="w-3 h-3 inline"></i>
   Dữ liệu theo bộ lọc đã chọn
  </div>
    </div>

    <div class="mb-4 p-4 bg-blue-50 border border-blue-200 rounded-lg">
        <p class="text-gray-700 mb-2">
            Biểu đồ phân tán giúp phát hiện các trường hợp bất thường và hiệu suất kém ổn định:
        </p>
        <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-gray-600 text-sm">
            <div>• Góc dưới bên phải (Độ chính xác cao, Thời gian thấp) = Hiệu suất Tốt nhất</div>
            <div>• Vùng chính giữa (Độ chính xác trung bình, Thời gian xử lý thấp) = Hiệu suất Trung bình</div>
            <div>• Vùng bên trái và phía trên (Độ chính xác thấp, Thời gian xử lý cao) = Hiệu suất Kém</div>
            <div>• Điểm nằm xa cụm chính đại diện cho các trường hợp bất thường, cần xem xét điều tra chi tiết</div>
        </div>
    </div>

    <div style="height: 500px;">
        <canvas id="scatterChart"></canvas>
    </div>

    <!-- Legend -->
    <div class="mt-4 flex items-center justify-center gap-6 flex-wrap">
        <div class="flex items-center gap-2">
            <div class="w-3 h-3 rounded-full" style="background-color: rgba(34, 197, 94, 0.6);"></div>
     <span class="text-gray-700">Tốt (≥90% & ≤3s)</span>
        </div>
  <div class="flex items-center gap-2">
       <div class="w-3 h-3 rounded-full" style="background-color: rgba(250, 204, 21, 0.6);"></div>
            <span class="text-gray-700">Trung bình (80-90% & ≤3s)</span>
        </div>
        <div class="flex items-center gap-2">
     <div class="w-3 h-3 rounded-full" style="background-color: rgba(251, 146, 60, 0.6);"></div>
     <span class="text-gray-700">Cần cải thiện (80-90% & &gt;3s)</span>
</div>
        <div class="flex items-center gap-2">
         <div class="w-3 h-3 rounded-full" style="background-color: rgba(239, 68, 68, 0.6);"></div>
        <span class="text-gray-700">Kém (&lt;80% hoặc &gt;5s)</span>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const scatterData = @Html.Raw(Json.Serialize(Model));

        const dataPoints = scatterData.map(item => ({
            x: item.accuracy,
            y: Math.min(item.time, 5), // Clamp về max 5 để hiển thị
            actualTime: item.time, // Giữ giá trị thực cho tooltip
            template: item.template,
            id: item.id
        }));

        const backgroundColors = dataPoints.map(item => {
            // Kém: accuracy < 80% hoặc time > 5s
            if (item.x < 80 || item.y > 5) return 'rgba(239, 68, 68, 0.6)'; // red pastel
    // Cần cải thiện: accuracy 80-90% và time > 3s
         if (item.x >= 80 && item.x < 90 && item.y > 3) return 'rgba(251, 146, 60, 0.6)'; // orange pastel
            // Trung bình: accuracy 80-90% và time ≤ 3s
     if (item.x < 90) return 'rgba(250, 204, 21, 0.6)'; // yellow pastel
     // Tốt: accuracy ≥ 90% và time ≤ 3s
            return 'rgba(34, 197, 94, 0.6)'; // green pastel
        });

        new Chart(document.getElementById('scatterChart'), {
            type: 'scatter',
            data: {
                datasets: [{
                    label: 'OCR Jobs',
                    data: dataPoints,
                    backgroundColor: backgroundColors,
                    pointRadius: 6,
                    pointHoverRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: {
                        title: { display: true, text: 'Độ chính xác (%)' },
                        min: 70,
                        max: 100
                    },
                    y: {
                        title: { display: true, text: 'Thời gian xử lý (s/trang)' },
                        min: 0,
                        max: 5
                    }
                },
                plugins: {
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const point = context.raw;
                                return `${point.id} (${point.template}): ${point.x}% - ${point.actualTime}s`;
                            }
                        }
                    },
                    legend: {
                        display: false
                    },
                    annotation: {
                        annotations: {
                            line1: {
                                type: 'line',
                                xMin: 90,
                                xMax: 90,
                                borderColor: '#ef4444',
                                borderWidth: 1,
                                borderDash: [5, 5]
                            },
                            line2: {
                                type: 'line',
                                yMin: 3,
                                yMax: 3,
                                borderColor: '#ef4444',
                                borderWidth: 1,
                                borderDash: [5, 5]
                            }
                        }
                    }
                }
            }
        });
    });
</script>
