{
  "ConnectionStrings": {   
    "DefaultConnection": "unused",
    "TrungGianConnectionString": "unused"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "OcrDashboardMvc.Database.SqlApiProxyDatabase": "Debug",
      "OcrDashboardMvc.Services.DashboardService": "Debug"
    }
  },
  "LicenseSettings": {
    "TotalLicensePages": 250000,
    "WarningThreshold": 80,
    "CriticalThreshold": 90
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Extensions": "Warning",
        "System": "Warning",
        "OcrDashboardMvc": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/ocr-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
