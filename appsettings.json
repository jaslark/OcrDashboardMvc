{
  "ConnectionStrings": {
    "TrungGianConnectionString": "Host=localhost;Port=5432;Database=OCRMVCDatabase;Username=postgres;Password=123456;Timezone=Asia/Ho_Chi_Minh"
  },
  "LicenseSettings": {
    "TotalLicensePages": 250000,
    "WarningThreshold": 80,
    "CriticalThreshold": 90
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Extensions": "Warning",
        "System": "Warning",
        "OcrDashboardMvc": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/ocr-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
